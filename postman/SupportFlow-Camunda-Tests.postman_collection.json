    {
      "name": "8. Vérifier l'historique complet",
      "item": [
        {
          "name": "Historique du ticket",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"History contains all actions\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "    pm.expect(jsonData.length).to.be.greaterThan(5);",
                  "    ",
                  "    var actions = jsonData.map(h => h.action);",
                  "    pm.expect(actions).to.include(\"CREATION\");",
                  "    pm.expect(actions).to.include(\"ASSIGNATION\");",
                  "    pm.expect(actions).to.include(\"ESCALADE_MANUELLE\");",
                  "    pm.expect(actions).to.include(\"ESCALADE_SLA\");",
                  "    pm.expect(actions).to.include(\"RESOLUTION\");",
                  "    pm.expect(actions).to.include(\"CLOTURE\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tickets/{{ticket_id}}/history",
              "host": ["{{base_url}}"],
              "path": ["tickets", "{{ticket_id}}", "history"]
            }
          },
          "response": []
        }
      ]
