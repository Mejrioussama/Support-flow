{
  "info": {
    "name": "SupportFlow - Tests Camunda",
    "description": "Collection de tests pour valider l'intégration Camunda BPM",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8082/api",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "ticket_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "process_instance_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "0. Authentification",
      "item": [
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Token received\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.token).to.exist;",
                  "    pm.collectionVariables.set(\"jwt_token\", jsonData.token);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin@supportflow.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "1. Créer un ticket (Démarre Camunda)",
      "item": [
        {
          "name": "Créer ticket HIGH priority",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Ticket created with processInstanceId\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.id).to.exist;",
                  "    pm.expect(jsonData.reference).to.exist;",
                  "    pm.expect(jsonData.processInstanceId).to.exist;",
                  "    pm.expect(jsonData.status).to.eql(\"OPEN\");",
                  "    ",
                  "    pm.collectionVariables.set(\"ticket_id\", jsonData.id);",
                  "    pm.collectionVariables.set(\"process_instance_id\", jsonData.processInstanceId);",
                  "    ",
                  "    console.log(\"Ticket ID: \" + jsonData.id);",
                  "    console.log(\"Process Instance ID: \" + jsonData.processInstanceId);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Test Camunda - Erreur API Paiement\",\n  \"description\": \"Test du workflow Camunda avec escalade SLA\",\n  \"type\": \"INCIDENT\",\n  \"severity\": \"HIGH\",\n  \"impact\": \"HIGH\",\n  \"clientId\": 1,\n  \"category\": \"API\",\n  \"tags\": [\"camunda\", \"test\", \"sla\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/tickets",
              "host": ["{{base_url}}"],
              "path": ["tickets"]
            }
          },
          "response": []
        },
        {
          "name": "Vérifier le ticket créé",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Ticket has Camunda data\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.processInstanceId).to.exist;",
                  "    pm.expect(jsonData.slaHours).to.exist;",
                  "    pm.expect(jsonData.slaDeadline).to.exist;",
                  "    pm.expect(jsonData.score).to.be.greaterThan(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tickets/{{ticket_id}}",
              "host": ["{{base_url}}"],
              "path": ["tickets", "{{ticket_id}}"]
            }
          },
          "response": []
        }
      ]
    },
